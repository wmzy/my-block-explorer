{
  "name": "my-block-explorer",
  "version": "0.0.0",
  "type": "module",
  "description": "Multi-chain blockchain explorer with auto-discovery",
  "bin": {
    "my-block-explorer": "./dist/server/cli.js"
  },
  "files": [
    "dist/server",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/server/server.js",
  "exports": {
    ".": {
      "types": "./dist/server/server.d.ts",
      "import": "./dist/server/server.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wmzy/my-block-explorer.git"
  },
  "keywords": [
    "blockchain",
    "explorer",
    "ethereum",
    "multi-chain",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/cli.ts -- --port 8201",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup",
    "build:pages": "VITE_BASE=/my-block-explorer/ vite build",
    "start": "node dist/server/cli.js",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.1-r.1",
    "@duckdb/node-bindings-darwin-arm64": "1.5.0-r.1",
    "@hono/node-server": "^1.19.11",
    "@linaria/core": "^7.0.0",
    "@linaria/react": "^7.0.1",
    "@tanstack/react-query": "^5.91.0",
    "drizzle-orm": "^0.45.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "evmole": "^0.8.4",
    "haze-ui": "^1.5.5",
    "hono": "^4.12.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-use-control": "^1.3.2",
    "sonner": "^2.0.7",
    "storage-layout-fetcher": "^0.2.1",
    "undici": "^7.24.5",
    "viem": "^2.47.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@wyw-in-js/babel-preset": "^1.0.6",
    "@wyw-in-js/vite": "^1.0.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "react-use-control": "^1.3.1"
    }
  }
}
